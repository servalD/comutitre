# Production environment (docker compose -f docker/docker-compose.prod.yml).
# In Swarm (docker/stack.prod.yml), APP_JWT_SECRET and POSTGRES_PASSWORD are
# provided as Docker secrets instead of plain env values.
NODE_ENV=production
PORT=3000
CORS_ORIGIN=https://comutitre.example.com
FRONTEND_URL=https://comutitre.example.com

POSTGRES_DB=comutitre
POSTGRES_USER=comutitre
POSTGRES_PASSWORD=use-a-strong-secret
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=comutitre
DATABASE_USER=comutitre
DATABASE_PASSWORD=use-a-strong-secret

# Generate with: openssl rand -base64 32
APP_JWT_SECRET=generate-a-strong-secret
APP_JWT_EXPIRES_IN=1h

DYNAMIC_ENVIRONMENT_ID=your-production-dynamic-environment-id

FRANCECONNECT_MODE=live
FRANCECONNECT_CLIENT_ID=your-franceconnect-client-id
FRANCECONNECT_CLIENT_SECRET=your-franceconnect-client-secret
FRANCECONNECT_ISSUER_URL=https://app.franceconnect.gouv.fr/api/v2
FRANCECONNECT_REDIRECT_URI=https://api.comutitre.example.com/auth/franceconnect/callback
