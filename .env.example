# ---------------------------------------------------------------------------
# Comutitre — environment template. Copy to .env.dev / .env.test / .env.prod
# and fill the values. Never commit real secrets (only *.example is tracked).
# ---------------------------------------------------------------------------

# Runtime
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# PostgreSQL (consumed by both the app and the postgres container)
POSTGRES_DB=comutitre
POSTGRES_USER=comutitre
POSTGRES_PASSWORD=change-me
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=comutitre
DATABASE_USER=comutitre
DATABASE_PASSWORD=change-me

# App session JWT (issued by the back after a FranceConnect login)
# Generate with: openssl rand -base64 32
APP_JWT_SECRET=change-me-with-openssl-rand-base64-32
APP_JWT_EXPIRES_IN=1h

# Dynamic.xyz — the back verifies front-issued tokens against this env's JWKS
DYNAMIC_ENVIRONMENT_ID=your-dynamic-environment-id

# FranceConnect (OIDC) — placeholders until real credentials are provisioned.
# mock = run the flow locally without contacting FranceConnect.
FRANCECONNECT_MODE=mock
FRANCECONNECT_CLIENT_ID=placeholder-client-id
FRANCECONNECT_CLIENT_SECRET=placeholder-client-secret
FRANCECONNECT_ISSUER_URL=https://fcp.integ01.dev-franceconnect.fr/api/v1
FRANCECONNECT_REDIRECT_URI=http://localhost:3000/auth/franceconnect/callback
