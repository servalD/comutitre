# ---------------------------------------------------------------------------
# Comutitre — environment template. Copy to .env.dev / .env.test / .env.prod
# and fill the values. Never commit real secrets (only *.example is tracked).
# ---------------------------------------------------------------------------

# Runtime
export NODE_ENV=development
export PORT=3000
export CORS_ORIGIN=http://localhost:5173
export FRONTEND_URL=http://localhost:5173

# PostgreSQL (consumed by both the app and the postgres container)
export POSTGRES_DB=comutitre
export POSTGRES_USER=comutitre
export POSTGRES_PASSWORD=change-me
export DATABASE_HOST=localhost
export DATABASE_PORT=5432
export DATABASE_NAME=comutitre
export DATABASE_USER=comutitre
export DATABASE_PASSWORD=change-me

# App session JWT (issued by the back after a FranceConnect login)
# Generate with: openssl rand -base64 32
export APP_JWT_SECRET=change-me-with-openssl-rand-base64-32
export APP_JWT_EXPIRES_IN=1h

# Dynamic.xyz — the back verifies front-issued tokens against this env's JWKS
export DYNAMIC_ENVIRONMENT_ID=your-dynamic-environment-id

# FranceConnect (OIDC) — placeholders until real credentials are provisioned.
export # mock = run the flow locally without contacting FranceConnect.
export FRANCECONNECT_MODE=mock
export FRANCECONNECT_CLIENT_ID=placeholder-client-id
export FRANCECONNECT_CLIENT_SECRET=placeholder-client-secret
export FRANCECONNECT_ISSUER_URL=https://fcp.integ01.dev-franceconnect.fr/api/v1
export FRANCECONNECT_REDIRECT_URI=http://localhost:3000/auth/franceconnect/callback
