# Test environment (e2e). The test DB runs on port 5433 via
# docker/docker-compose.test.yml (tmpfs, no persistence). CI may override
# DATABASE_HOST/PORT to point at its postgres service.
export NODE_ENV=test
export PORT=3001
export CORS_ORIGIN=http://localhost:5173
export FRONTEND_URL=http://localhost:5173

export POSTGRES_DB=comutitre_test
export POSTGRES_USER=comutitre_test
export POSTGRES_PASSWORD=comutitre_test
export DATABASE_HOST=localhost
export DATABASE_PORT=5433
export DATABASE_NAME=comutitre_test
export DATABASE_USER=comutitre_test
export DATABASE_PASSWORD=comutitre_test

export APP_JWT_SECRET=test-only-secret-change-me-please-32
export APP_JWT_EXPIRES_IN=1h

export DYNAMIC_ENVIRONMENT_ID=test-environment-id

export FRANCECONNECT_MODE=mock
export FRANCECONNECT_CLIENT_ID=placeholder-client-id
export FRANCECONNECT_CLIENT_SECRET=placeholder-client-secret
export FRANCECONNECT_ISSUER_URL=https://fcp.integ01.dev-franceconnect.fr/api/v1
export FRANCECONNECT_REDIRECT_URI=http://localhost:3001/auth/franceconnect/callback
